# panma-harness — Verification Checks Library (example template)
#
# Read by the Designer to pick a subset of checks for each cycle, then
# executed by the Verifier in its dynamic phase.
#
# A "check" is just a shell command. You do NOT need a specific testing
# framework (playwright / cypress / etc.) — anything that exits 0 on
# success and nonzero on failure works: `curl + bash`, `psql -c "..."`,
# a custom CLI runner, an integration script. The point is to verify the
# combined behavior across domains, not to use any particular tool.
#
# Designer's selection rule (per check):
#   include if ANY of applicable_when[] matches:
#     - user_hint: list of keywords; matches case-insensitively against
#       the user_request
#     - changed: list of glob patterns; matches if any executor's outputs
#       (or inputs) intersect the globs
#   if applicable_when is missing or empty → always include
#
# Verifier execution rule (per included check):
#   - run `cmd` in `cwd` (default project root) with `timeout` (default 300)
#   - record pass / fail / timeout / skipped + duration + last ~20 lines
#   - overall verifier status = pass only when every dynamic check passes
#     (skipped also counts as pass)
#
# Failed checks are reported back to Designer with the rest of the verifier
# output, so the re-plan can decide whether to fix code, change the
# verification picks, or escalate.

checks:
  # --- example: plain cross-cutting smoke (no framework, just a shell cmd)
  # The simplest form: hit a real endpoint and assert. Works for any stack.
  - id: cross-cutting-smoke
    description: "Verify the combined system answers after backend+frontend changes"
    cmd: <your-cross-cutting-check-command>
    timeout: 300
    applicable_when:
      - changed: ["<frontend-glob>", "<backend-glob>"]

  # --- example: framework-based smoke (when you happen to have one)
  - id: ui-smoke
    description: "Playwright / Cypress smoke (login + main flow)"
    cmd: <your-framework-smoke-command>
    timeout: 300
    applicable_when:
      - changed: ["<frontend-glob>", "<backend-glob>"]

  # --- example: full e2e (only when user explicitly asks)
  - id: ui-full
    description: "Full playwright e2e suite (slow)"
    cmd: <your-full-e2e-command>
    timeout: 1200
    applicable_when:
      - user_hint: ["playwright", "e2e", "full check"]

  # --- example: contract test against backend
  - id: api-contract
    description: "Hit each declared API endpoint with a sample payload"
    cmd: <your-contract-test-command>
    timeout: 60
    cwd: "<optional-subdir>"        # default project root
    applicable_when:
      - changed: ["<backend-glob>"]

  # --- example: always-on quick check (no applicable_when → always included)
  - id: schema-validate
    description: "Validate JSON schemas / OpenAPI spec are well-formed"
    cmd: <your-schema-validation-command>
    timeout: 30

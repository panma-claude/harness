{
  "description": "panma-harness orchestration hooks",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT\"/hooks/inject-trigger.sh",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
